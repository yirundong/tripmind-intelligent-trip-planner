<mxfile host="app.diagrams.net" type="device">
  <diagram name="智能旅行规划活动图" id="actPlan">
    <mxGraphModel dx="1100" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="lu" value="用户" style="swimlane;html=1;startSize=30;horizontal=1;fontSize=14;fontStyle=1;fillColor=#ffffff;strokeColor=#000000;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="380" height="840" as="geometry"/></mxCell>
        <mxCell id="ls" value="系统" style="swimlane;html=1;startSize=30;horizontal=1;fontSize=14;fontStyle=1;fillColor=#ffffff;strokeColor=#000000;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="420" y="20" width="540" height="840" as="geometry"/></mxCell>
        <mxCell id="u_start" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lu"><mxGeometry x="180" y="50" width="20" height="20" as="geometry"/></mxCell>
        <mxCell id="u1" value="填写目的地、日期、人数、预算等旅行需求" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="60" y="90" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="u2" value="提交规划请求" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="90" y="170" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u3" value="等待规划完成" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="90" y="350" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u4" value="查看生成的行程方案" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="90" y="730" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u_end_outer" value="" style="ellipse;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="lu"><mxGeometry x="175" y="800" width="30" height="30" as="geometry"/></mxCell>
        <mxCell id="u_end_inner" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lu"><mxGeometry x="182" y="807" width="16" height="16" as="geometry"/></mxCell>
        <mxCell id="s1" value="接收并启动规划任务" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="170" y="240" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="s2" value="并行采集景点、天气、酒店等出行信息" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="150" y="320" width="260" height="50" as="geometry"/></mxCell>
        <mxCell id="s3" value="综合采集到的信息生成行程方案" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="170" y="400" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="s4" value="检查方案是否合理" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="180" y="470" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="s_dec" value="合理？" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="200" y="540" width="160" height="70" as="geometry"/></mxCell>
        <mxCell id="s_repair" value="对不合理之处进行修复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="20" y="555" width="160" height="40" as="geometry"/></mxCell>
        <mxCell id="s5" value="保存方案并通知用户" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="170" y="660" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="u_start" target="u1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="u1" target="u2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="u2" target="s1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="s1" target="u3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="endArrow=classic;html=1;" edge="1" parent="1" source="s4" target="s_dec"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="否" style="endArrow=classic;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="s_dec" target="s_repair"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" value="重新检查" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="s_repair" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" value="是" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="s_dec" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;" edge="1" parent="1" source="s5" target="u4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" style="endArrow=classic;html=1;" edge="1" parent="1" source="u4" target="u_end_outer"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
