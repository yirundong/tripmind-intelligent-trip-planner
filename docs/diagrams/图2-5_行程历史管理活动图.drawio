<mxfile host="app.diagrams.net" type="device">
  <diagram name="行程历史管理活动图" id="actHist">
    <mxGraphModel dx="900" dy="1700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- 垂直泳道 -->
        <mxCell id="lu" value="用户" style="swimlane;html=1;startSize=30;horizontal=1;fontSize=14;fontStyle=1;fillColor=#ffffff;strokeColor=#000000;swimlaneFillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="350" height="1620" as="geometry"/>
        </mxCell>
        <mxCell id="ls" value="系统" style="swimlane;html=1;startSize=30;horizontal=1;fontSize=14;fontStyle=1;fillColor=#ffffff;strokeColor=#000000;swimlaneFillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="420" y="20" width="350" height="1620" as="geometry"/>
        </mxCell>
        <!-- ====== 用户节点 ====== -->
        <mxCell id="u_start" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" value="" vertex="1" parent="lu">
          <mxGeometry x="165" y="50" width="20" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="u1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="进入历史行程页面" vertex="1" parent="lu">
          <mxGeometry x="75" y="110" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="u_browse" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="浏览历史行程列表" vertex="1" parent="lu">
          <mxGeometry x="75" y="380" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="u_op" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="选择操作" vertex="1" parent="lu">
          <mxGeometry x="85" y="480" width="180" height="80" as="geometry"/>
        </mxCell>
        <!-- 查看分支 -->
        <mxCell id="u_view" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="点击查看某条行程" vertex="1" parent="lu">
          <mxGeometry x="75" y="640" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="u_view_done" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="查看行程详细安排" vertex="1" parent="lu">
          <mxGeometry x="75" y="830" width="200" height="40" as="geometry"/>
        </mxCell>
        <!-- 删除分支 -->
        <mxCell id="u_del_click" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="点击删除按钮" vertex="1" parent="lu">
          <mxGeometry x="75" y="980" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="u_confirm" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="确认删除？" vertex="1" parent="lu">
          <mxGeometry x="85" y="1170" width="180" height="80" as="geometry"/>
        </mxCell>
        <!-- 结束 -->
        <mxCell id="u_end_outer" style="ellipse;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;" value="" vertex="1" parent="lu">
          <mxGeometry x="160" y="1550" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="u_end_inner" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" value="" vertex="1" parent="lu">
          <mxGeometry x="167" y="1557" width="16" height="16" as="geometry"/>
        </mxCell>
        <!-- ====== 系统节点 ====== -->
        <mxCell id="s_auth" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="识别用户身份" vertex="1" parent="ls">
          <mxGeometry x="75" y="160" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="s_dec" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="身份有效？" vertex="1" parent="ls">
          <mxGeometry x="85" y="240" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s_login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" value="提示重新登录" vertex="1" parent="ls">
          <mxGeometry x="75" y="370" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="s_list" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="按时间倒序返回历史行程列表" vertex="1" parent="ls">
          <mxGeometry x="60" y="460" width="230" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="s_detail" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="展示该条行程的详细安排" vertex="1" parent="ls">
          <mxGeometry x="65" y="730" width="220" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="s_pop" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="弹出删除确认对话框" vertex="1" parent="ls">
          <mxGeometry x="75" y="1070" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="s_del" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="删除该条行程并刷新列表" vertex="1" parent="ls">
          <mxGeometry x="65" y="1350" width="220" height="40" as="geometry"/>
        </mxCell>
        <!-- ====== 连线 ====== -->
        <!-- 起始→进入页面 -->
        <mxCell id="e1" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_start" target="u1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 进入页面→识别身份（跨泳道水平） -->
        <mxCell id="e2" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="u1" target="s_auth">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="150" />
              <mxPoint x="405" y="200" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 识别身份→判断 -->
        <mxCell id="e3" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="s_auth" target="s_dec">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 否→提示重新登录（向下） -->
        <mxCell id="e4" value="否" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="s_dec" target="s_login">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 提示重新登录→结束（跨泳道，虚线） -->
        <mxCell id="e_login_end" style="endArrow=classic;html=1;dashed=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s_login" target="u_end_outer">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="410" />
              <mxPoint x="405" y="1585" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 是→返回列表（沿右侧绕过"提示重新登录"） -->
        <mxCell id="e5" value="是" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="s_dec" target="s_list">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="300" />
              <mxPoint x="750" y="500" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 返回列表→浏览（跨泳道水平） -->
        <mxCell id="e6" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s_list" target="u_browse">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="500" />
              <mxPoint x="405" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 浏览→选择操作 -->
        <mxCell id="e7" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_browse" target="u_op">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 选择操作→查看（向下） -->
        <mxCell id="e8" value="查看详情" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_op" target="u_view">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 查看→系统展示详情（跨泳道水平） -->
        <mxCell id="e10" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="u_view" target="s_detail">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="680" />
              <mxPoint x="405" y="770" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 系统展示→用户查看完成（跨泳道水平） -->
        <mxCell id="e11" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s_detail" target="u_view_done">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="770" />
              <mxPoint x="405" y="870" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 查看完成→结束 -->
        <mxCell id="e12" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_view_done" target="u_end_outer">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 选择操作→删除（沿右侧边缘向下跳到删除区域） -->
        <mxCell id="e9" value="删除" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_op" target="u_del_click">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="540" />
              <mxPoint x="340" y="1020" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 删除按钮→弹出确认（跨泳道水平） -->
        <mxCell id="e13" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="u_del_click" target="s_pop">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="1020" />
              <mxPoint x="405" y="1110" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 弹出确认→用户确认（跨泳道水平） -->
        <mxCell id="e14" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s_pop" target="u_confirm">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="1110" />
              <mxPoint x="405" y="1230" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 确认删除-否: 沿左侧边缘向上回到浏览 -->
        <mxCell id="e15" value="否" style="endArrow=classic;html=1;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_confirm" target="u_browse">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="70" y="1230" />
              <mxPoint x="70" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 确认删除-是: 向下到系统删除（跨泳道） -->
        <mxCell id="e16" value="是" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="u_confirm" target="s_del">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="225" y="1310" />
              <mxPoint x="405" y="1310" />
              <mxPoint x="405" y="1390" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- 系统删除→结束（跨泳道） -->
        <mxCell id="e17" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="s_del" target="u_end_outer">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="405" y="1390" />
              <mxPoint x="405" y="1585" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
