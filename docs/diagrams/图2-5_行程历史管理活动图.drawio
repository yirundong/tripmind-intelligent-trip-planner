<mxfile host="app.diagrams.net" type="device">
  <diagram name="行程历史管理活动图" id="actHist">
    <mxGraphModel dx="1100" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="lu" value="用户" style="swimlane;html=1;startSize=30;horizontal=1;fontSize=14;fontStyle=1;fillColor=#ffffff;strokeColor=#000000;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="440" height="940" as="geometry"/></mxCell>
        <mxCell id="ls" value="系统" style="swimlane;html=1;startSize=30;horizontal=1;fontSize=14;fontStyle=1;fillColor=#ffffff;strokeColor=#000000;swimlaneFillColor=#ffffff;" vertex="1" parent="1"><mxGeometry x="480" y="20" width="500" height="940" as="geometry"/></mxCell>
        <mxCell id="u_start" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lu"><mxGeometry x="210" y="50" width="20" height="20" as="geometry"/></mxCell>
        <mxCell id="u1" value="进入历史行程页面" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="120" y="90" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u_browse" value="浏览历史行程列表" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="120" y="320" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u_op" value="选择操作" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="140" y="390" width="160" height="70" as="geometry"/></mxCell>
        <mxCell id="u_view" value="点击查看某条行程" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="20" y="500" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u_view_done" value="查看行程详细安排" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="20" y="650" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u_del_click" value="点击删除按钮" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="220" y="500" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="u_confirm" value="确认删除？" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="lu"><mxGeometry x="240" y="650" width="160" height="70" as="geometry"/></mxCell>
        <mxCell id="u_end_outer" value="" style="ellipse;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="lu"><mxGeometry x="205" y="880" width="30" height="30" as="geometry"/></mxCell>
        <mxCell id="u_end_inner" value="" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="lu"><mxGeometry x="212" y="887" width="16" height="16" as="geometry"/></mxCell>
        <mxCell id="s_auth" value="识别用户身份" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="150" y="90" width="200" height="40" as="geometry"/></mxCell>
        <mxCell id="s_dec" value="身份有效？" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="170" y="160" width="160" height="70" as="geometry"/></mxCell>
        <mxCell id="s_login" value="提示重新登录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="350" y="175" width="140" height="40" as="geometry"/></mxCell>
        <mxCell id="s_list" value="按时间倒序返回历史行程列表" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="130" y="250" width="240" height="40" as="geometry"/></mxCell>
        <mxCell id="s_detail" value="展示该条行程的详细安排" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="20" y="570" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="s_pop" value="弹出删除确认对话框" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="260" y="570" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="s_del" value="删除该条行程并刷新列表" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="ls"><mxGeometry x="260" y="780" width="220" height="40" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="u_start" target="u1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="u1" target="s_auth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="s_auth" target="s_dec"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="否" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="s_dec" target="s_login"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="是" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="s_dec" target="s_list"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_login_end" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="s_login" target="u_end_outer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;" edge="1" parent="1" source="s_list" target="u_browse"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;" edge="1" parent="1" source="u_browse" target="u_op"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" value="查看详情" style="endArrow=classic;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="u_op" target="u_view"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="删除" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="u_op" target="u_del_click"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;" edge="1" parent="1" source="u_view" target="s_detail"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;" edge="1" parent="1" source="s_detail" target="u_view_done"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;" edge="1" parent="1" source="u_view_done" target="u_end_outer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" style="endArrow=classic;html=1;" edge="1" parent="1" source="u_del_click" target="s_pop"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" style="endArrow=classic;html=1;" edge="1" parent="1" source="s_pop" target="u_confirm"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" value="否" style="endArrow=classic;html=1;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="u_confirm" target="u_browse"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e16" value="是" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="u_confirm" target="s_del"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e17" style="endArrow=classic;html=1;" edge="1" parent="1" source="s_del" target="u_end_outer"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
