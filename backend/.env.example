# TripMind backend environment

# FastAPI server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# Database and auth
# SQLite is recommended for local demonstration. Change this URL when migrating to MySQL/PostgreSQL.
DATABASE_URL=sqlite:///./trip_planner.db
JWT_SECRET_KEY=please-change-this-local-secret
JWT_EXPIRE_MINUTES=10080

# LLM service, OpenAI-compatible endpoint used by LangChain ChatOpenAI
LLM_MODEL_ID=your-model-name
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=your-api-base-url
LLM_TIMEOUT=60

# AMap Web Service API key, used by backend POI/weather/route requests
AMAP_API_KEY=your-amap-web-service-key

# Optional Unsplash image service
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
