# TripMind frontend environment

# Backend API base URL. Keep localhost for local development.
VITE_API_BASE_URL=http://localhost:8000

# AMap JS API key and security code, used by result/explore map rendering.
VITE_AMAP_WEB_JS_KEY=your-amap-js-api-key
VITE_AMAP_SECURITY_JS_CODE=your-amap-security-js-code
